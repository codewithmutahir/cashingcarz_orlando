# Copy to .env and fill in real values. On production use APP_ENV=production and APP_DEBUG=false.

APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_LOCALE=en
FALLBACK_LOCALE_FOR_DB=en
APP_VERSION=14.2.0

PURCHASE_CODE=
TIMEZONE=UTC
FORCE_HTTPS=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SOCKET=
DB_TABLES_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_DUMP_BINARY_PATH=

APP_API_TOKEN=
APP_HTTP_CLIENT=none

IMAGE_DRIVER=gd

CACHE_DRIVER=file
CACHE_PREFIX=lc_
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=360

LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DAYS=14

DISABLE_USERNAME=true

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
MAIL_VERIFY_PEER=true

DEBUG_BAR=false
DEBUGBAR_ENABLED=false
SNOW_EFFECT=false

# Composer / GitHub (CI and hosts that run `composer update` or install many packages):
# Without a token, GitHub API rate limits can fail with "Could not authenticate against github.com".
# Create a classic PAT (read-only is enough for public repos): https://github.com/settings/tokens
# Then set in your host environment (or COMPOSER_AUTH JSON — see Composer docs).
# GITHUB_TOKEN=
